{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "gnuplot",
      "camelcase": "yes",
      "title": "gnuplot",
      "scope": "source.gnuplot",
      "file-types": [
        "gnuplot"
      ],
      "injection-regex": "^gnuplot$",
      "class-name": "TreeSitterGnuplot"
    }
  ],
  "metadata": {
    "version": "2.0.1",
    "license": "MIT",
    "description": "A tree-sitter grammar for gnuplot",
    "authors": [
      {
        "name": "Dai López Jacinto",
        "email": "dpezto@gmail.com",
        "url": "https://github.com/dpezto"
      }
    ],
    "links": {
      "repository": "https://github.com/dpezto/tree-sitter-gnuplot",
      "funding": "https://github.com/dpezto/tree-sitter-gnuplot"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}
